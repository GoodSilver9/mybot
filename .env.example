# =============================================================================
# Discord Music Bot 환경 설정
# 이 파일을 .env 로 복사 후 값을 채우세요.
# =============================================================================

# [필수] Discord 봇 토큰
# https://discord.com/developers/applications 에서 발급
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# -----------------------------------------------------------------------------
# [선택] Spotify API — .mind / .sp / .ps / .similar / .auto / .playlist 사용 시 필요
# https://developer.spotify.com/dashboard
# -----------------------------------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# 기본 플레이리스트(인자 없이 .playlist 호출 시 사용)
# SPOTIFY_DEFAULT_PLAYLIST_URL=https://open.spotify.com/playlist/xxxxx

# -----------------------------------------------------------------------------
# [선택] DeepSeek API — .jp / .kr / .en / .search 사용 시 필요
# 이전에는 코드에 하드코딩되어 있었으나 보안상 환경변수로만 받습니다.
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=
# DEEPSEEK_API_URL=https://api.deepseek.com/chat/completions

# -----------------------------------------------------------------------------
# [선택] FFmpeg / Node.js 경로 (setup.bat 실행 시 자동 기록됨)
# -----------------------------------------------------------------------------
# FFMPEG_PATH=ffmpeg
# NODE_PATH=node

# -----------------------------------------------------------------------------
# [선택] 동작 옵션
# -----------------------------------------------------------------------------
# 봇 명령 prefix (기본값 .)
COMMAND_PREFIX=.
# 명령어 대소문자 무시 여부 (true/false)
# CASE_INSENSITIVE=true
# 음성 연결 timeout 초 (기본 30)
# VOICE_TIMEOUT=30
# 로그 파일 디렉터리 (기본: <project>/logs)
# LOG_DIR=logs
