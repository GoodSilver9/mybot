# Discord Bot Token
# Discord Developer Portal (https://discord.com/developers/applications) 에서 발급
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Spotify API Keys (선택사항 - .mind, .sp, .similar, .auto 명령어 사용 시 필요)
# https://developer.spotify.com/dashboard 에서 발급
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# FFmpeg 경로 (기본값: ffmpeg - PATH에 있으면 생략 가능)
# setup.bat 실행 시 자동 설치됨
# FFMPEG_PATH=ffmpeg

# 봇 설정 (선택사항)
# COMMAND_PREFIX=.
# CASE_INSENSITIVE=true
# VOICE_TIMEOUT=30.0
